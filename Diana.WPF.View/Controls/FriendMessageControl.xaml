<UserControl x:Class="Diana.WPF.View.Controls.FriendMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="58"
             MinWidth="200"
             MaxWidth="420"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Bubble shadow -->
        <DropShadowEffect x:Key="BubbleShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.08"
                          Color="#6070C0"/>

        <!-- Avatar style -->
        <Style x:Key="AvatarEllipse" TargetType="Ellipse">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>

    </UserControl.Resources>

    <!-- Root card -->
    <Border x:Name="RootCard"
            Background="#EDF1FC"
            CornerRadius="14"
            Padding="8"
            Margin="0,0,0,4">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═════════ Avatar ═════════ -->
            <Grid Grid.Column="0"
                  Width="40"
                  Height="40"
                  VerticalAlignment="Top">

                <!-- Fallback background -->
                <Ellipse x:Name="AvatarFallback"
                         Style="{StaticResource AvatarEllipse}"
                         StrokeThickness="0">

                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">
                            <GradientStop Color="#7B9EE8"
                                          Offset="0"/>
                            <GradientStop Color="#3D65C4"
                                          Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Initials -->
                <TextBlock x:Name="InitialsText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="16"
                           Foreground="White"/>

                <!-- Real avatar -->
                <Ellipse x:Name="AvatarImage"
                         Style="{StaticResource AvatarEllipse}"
                         Visibility="Collapsed">

                    <Ellipse.Fill>
                        <ImageBrush x:Name="AvatarBrush"
                                    Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

            </Grid>

            <!-- ═════════ Message Bubble ═════════ -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="10"
                    Padding="10 6"
                    VerticalAlignment="Top"
                    Effect="{StaticResource BubbleShadow}"
                    BorderBrush="#D2DCEF"
                    BorderThickness="1"
                    MaxWidth="320">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Username + Time -->
                    <Grid Grid.Row="0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Username -->
                        <TextBlock x:Name="UsernameText"
                                   Grid.Column="0"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Foreground="#3254A8"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                        <!-- Time -->
                        <TextBlock x:Name="TimeText"
                                   Grid.Column="1"
                                   FontSize="9"
                                   Foreground="#A0A8BB"
                                   Margin="6 0 0 0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Message -->
                    <TextBlock x:Name="MessageText"
                               Grid.Row="1"
                               FontSize="11"
                               Foreground="#50505A"
                               TextWrapping="Wrap"
                               MaxWidth="280"
                               Margin="0 4 0 0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>