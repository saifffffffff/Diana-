<UserControl x:Class="Diana.WPF.View.Controls.FriendMessageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="76" MinWidth="240" MaxWidth="480"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Bubble drop shadow -->
        <DropShadowEffect x:Key="BubbleShadow"
                          BlurRadius="14" ShadowDepth="2"
                          Direction="270" Opacity="0.10"
                          Color="#6070C0"/>

        <!-- Emoji drop shadow -->
        <DropShadowEffect x:Key="EmojiShadow"
                          BlurRadius="6" ShadowDepth="1"
                          Direction="270" Opacity="0.18"
                          Color="#000000"/>

        <!-- Rounded clip for avatar -->
        <Style x:Key="AvatarEllipse" TargetType="Ellipse">
            <Setter Property="Width"  Value="54"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Stroke" Value="White"/>
            <Setter Property="StrokeThickness" Value="2.5"/>
        </Style>

    </UserControl.Resources>

    <!-- Root card -->
    <Border x:Name="RootCard"
            Background="#EDF1FC"
            CornerRadius="18"
            Padding="10 11 14 11" Margin="0,0,0,-3" Width="402">

        <Grid Margin="0,0,-25,0">
            <Grid.ColumnDefinitions>
                <!-- Avatar -->
                <ColumnDefinition Width="54"/>
                <!-- Gap -->
                <ColumnDefinition Width="10"/>
                <!-- Bubble -->
                <ColumnDefinition Width="*"/>
                <!-- Gap -->
                <ColumnDefinition Width="8"/>
                <!-- Emoji -->
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <!-- ══ Avatar ══ -->
            <Grid Grid.Column="0" Width="54" Height="54"
                  VerticalAlignment="Center">

                <!-- Fallback initials (shown when no image) -->
                <Ellipse x:Name="AvatarFallback"
                         Style="{StaticResource AvatarEllipse}"
                         StrokeThickness="0">
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7B9EE8" Offset="0"/>
                            <GradientStop Color="#3D65C4" Offset="1"/>
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock x:Name="InitialsText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           FontSize="22"
                           Foreground="White"/>

                <!-- Actual avatar image (clipped to circle) -->
                <Ellipse x:Name="AvatarImage"
                         Style="{StaticResource AvatarEllipse}"
                         Visibility="Collapsed">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="AvatarBrush"
                                    Stretch="UniformToFill"
                                    RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- White ring on top -->
                <Ellipse Style="{StaticResource AvatarEllipse}"
                         Fill="Transparent"/>
            </Grid>

            <!-- ══ Message bubble ══ -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="14"
                    Padding="12 7 12 7"
                    VerticalAlignment="Center"
                    Effect="{StaticResource BubbleShadow}" Grid.ColumnSpan="3" Margin="0,0,20,0">

                <Border.BorderBrush>
                    <SolidColorBrush Color="#D2DCEF"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: username + time -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="UsernameText"
                                   Grid.Column="0"
                                   FontFamily="Segoe UI"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Foreground="#3254A8"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                        <TextBlock x:Name="TimeText"
                                   Grid.Column="1"
                                   FontFamily="Segoe UI"
                                   FontSize="10"
                                   Foreground="#A0A8BB"
                                   VerticalAlignment="Center"
                                   Margin="8 0 0 0"/>
                    </Grid>

                    <!-- Message text -->
                <TextBlock x:Name="MessageText"
                               Grid.Row="1"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="#50505A"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               MaxHeight="28"
                               Margin="0 2 0 0"/>
                </Grid>
            </Border>

            <!-- ══ Emoji ══ -->
        </Grid>
    </Border>
</UserControl>
