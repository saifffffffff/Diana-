<Window x:Class="Diana.WPF.View.Views.ChatRoomView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Room" Height="650" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117">

    <Grid Background="#0D1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Messages -->
            <RowDefinition Height="Auto"/>
            <!-- Input -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#2D3748" BorderThickness="0,0,0,1"
                Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="60" Height="60" CornerRadius="30" Background="#1C2333" Margin="0,0,12,0">
                        <TextBlock Text="💬" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="RoomTitle" Foreground="#E2E8F0" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="RoomOwnerText" Foreground="#8892A4" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <Button x:Name="LeaveButton" Grid.Column="1"
                        Style="{StaticResource DangerButton}" Width="100">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Leave" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ MESSAGES ═══ -->
        
        <Border Grid.Row="1" Background="#0D1117">
            <ScrollViewer x:Name="MessagesScroller"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="12,8">
                <StackPanel x:Name="MessagesList"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
            </ScrollViewer>
        </Border>
        <!-- ═══ INPUT BAR ═══ -->
        <Border Grid.Row="2" Background="#161B22"
                BorderBrush="#2D3748" BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1C2333"
                        BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8">
                    <TextBox x:Name="MessageBox"
                             Background="Transparent"
                             Foreground="#E2E8F0"
                             BorderThickness="0"
                             Padding="12,8"
                             Height="40"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             CaretBrush="#E2E8F0"/>
                </Border>

                <Button x:Name="SendButton" Grid.Column="2"
                        Style="{StaticResource PrimaryButton}" Height="40">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Send" VerticalAlignment="Center"/>
                        <TextBlock Text=" →" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
