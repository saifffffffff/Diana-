<Window x:Class="Diana.WPF.View.Views.LobbyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Diana.WPF.View.Controls"
        Title="Lobby" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        WindowStyle="SingleBorderWindow"
        >



    <Window.Resources>
        <!-- ListView item hover style -->
        <Style x:Key="RoomListItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="itemBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#2D3748"
                                Padding="16,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#1C2333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#1C2333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#0D1117">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- Title bar -->
            <RowDefinition Height="Auto"/>
            <!-- User / join panel -->
            <RowDefinition Height="*"/>
            <!-- Rooms list -->
            <RowDefinition Height="36"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ TITLE BAR ═══════════════ -->
        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#2D3748" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <!-- Chat bubble icon -->
                <Viewbox Width="26" Height="26" Margin="0,0,10,0">
                    <Canvas Width="24" Height="24">
                        <Ellipse Canvas.Left="0" Canvas.Top="0" Width="24" Height="20"
                                 Stroke="#A78BFA" StrokeThickness="2" Fill="Transparent"/>
                        <Ellipse Canvas.Left="4" Canvas.Top="9" Width="8" Height="8"
                                 Fill="#0D1117"/>
                        <Line X1="6" Y1="20" X2="2" Y2="24" Stroke="#A78BFA" StrokeThickness="2" Canvas.Left="-1" Canvas.Top="-4"/>
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Chat Rooms"
                           Foreground="#E2E8F0"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════ USER / JOIN PANEL ═══════════════ -->
        <Border Grid.Row="1" Background="#161B22"
                BorderBrush="#2D3748" BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <!-- Avatar -->
                    <ColumnDefinition Width="*"/>
                    <!-- Inputs -->
                </Grid.ColumnDefinitions>

                <!-- Avatar circle - using CircularPictureBox control -->
                <local:CircularPictureBox Grid.Column="0" x:Name="UserAvatar" 
                                           Width="58" Height="58"
                                           HorizontalAlignment="Left"/>

                <!-- Inputs + Buttons -->
                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Username"
                               Foreground="#8892A4" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Room Key"
                               Foreground="#8892A4" FontSize="11" FontWeight="SemiBold"/>

                    <!-- Username TextBox -->
                    <Border Grid.Column="0" Grid.Row="2" Background="#1C2333"
                            BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="👤" Foreground="#4A5568" Margin="10,0,0,0"
                                       VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="UsernameBox"
                                     Background="Transparent"
                                     Foreground="#E2E8F0"
                                     BorderThickness="0"
                                     Padding="30,8,10,8"
                                     Height="40"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="#E2E8F0"
                                     Tag="Enter username..."/>
                        </Grid>
                    </Border>

                    <!-- Room Key TextBox -->
                    <Border Grid.Column="2" Grid.Row="2" Background="#1C2333"
                            BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="🔒" Foreground="#4A5568" Margin="10,0,0,0"
                                       VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="RoomKeyBox"
                                     Background="Transparent"
                                     Foreground="#E2E8F0"
                                     BorderThickness="0"
                                     Padding="30,8,10,8"
                                     Height="40"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     CaretBrush="#E2E8F0"
                                     Tag="Enter room key..."/>
                        </Grid>
                    </Border>

                    <!-- Join Room Button -->
                    <Button x:Name="JoinButton" Grid.Column="4" Grid.Row="2"
                            Height="40" Style="{StaticResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="→" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Join Room" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Create Room Button -->
                    <Button x:Name="CreateButton" Grid.Column="6" Grid.Row="2"
                            Height="40" Style="{StaticResource SecondaryButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Create Room" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════ ROOMS LIST ═══════════════ -->
        <Border Grid.Row="2" Margin="20,20,20,0" Background="#161B22"
                BorderBrush="#2D3748" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Section header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Column header -->
                    <RowDefinition Height="*"/>
                    <!-- Items -->
                </Grid.RowDefinitions>

                <!-- Section title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,14,16,10">
                    <TextBlock Text="👥" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#E2E8F0" RenderTransformOrigin="0.5,0">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform Y="-2"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Available Rooms"
                               Foreground="#E2E8F0"
                               FontSize="15"
                               FontWeight="Bold"
                               VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform X="-3"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </StackPanel>

                <!-- Column headers -->
                <Border Grid.Row="1" Background="#1C2333"
                        BorderBrush="#2D3748" BorderThickness="0,1,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"
                                   Foreground="#4A5568" FontSize="12" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="12" Margin="0,0,6,0" Foreground="#4A5568"/>
                            <TextBlock Text="Room Name" Foreground="#4A5568" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <TextBlock Text="🔑" FontSize="12" Margin="0,0,6,0" Foreground="#4A5568"/>
                            <TextBlock Text="Room Key" Foreground="#4A5568" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="12" Margin="0,0,6,0" Foreground="#4A5568"/>
                            <TextBlock Text="Member" Foreground="#4A5568" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Room items -->
                <Grid Grid.Row="2">
                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Visible">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#1C2333" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="💬" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No rooms available"
                                   Foreground="#E2E8F0" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Create a room or join an existing one"
                                   Foreground="#4A5568" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ListView x:Name="RoomsList"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemContainerStyle="{StaticResource RoomListItemStyle}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True" Height="333" VerticalAlignment="Top">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="180"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding RoomIndex}"
                                               Foreground="#4A5568" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RoomName}"
                                               Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RoomKey}"
                                               Foreground="#8892A4" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding MemberCount}"
                                               Foreground="#8892A4" FontSize="13" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="3" Background="#0D1117"
                BorderBrush="#2D3748" BorderThickness="0,1,0,0"
                Padding="20,0" RenderTransformOrigin="0.5,0.5" Margin="0,10,0,0">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleX="0"/>
                    <RotateTransform/>
                    <TranslateTransform X="0"/>
                </TransformGroup>
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#EF4444" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Text="connecting to the server ..."
                           Foreground="#EF4444" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>